# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# `.env` is git-ignored. docker-compose reads it automatically for variable
# substitution (e.g. JWT_SECRET below).

# Postgres connection string.
# - For the API running INSIDE docker-compose, compose overrides this with the
#   `postgres` service host, so you don't need to set it for Docker.
# - For running the API NATIVELY (pnpm --filter api start:dev) against the
#   compose database, use localhost:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/money_flow

# Secret used to sign/verify JWT auth tokens. Use a long random string.
JWT_SECRET=replace-with-a-long-random-string

# Optional — API port (defaults to 3001).
# PORT=3001
