// =============================================================================
// MONEY FLOW APP — PRISMA SCHEMA (v4)
// =============================================================================
// Changes from v1:
//   [1] Account comment corrected: 3 default accounts seeded (not 5)
//   [2] is_active NOT added to Category — soft delete (deleted_at) handles
//       both default and custom categories uniformly
//   [3] currencyCode removed from Transaction — derived from debitAccount
//   [4] Currency relation removed from Transaction accordingly
//   [5] updatedAt removed from JournalEntry — immutable table, write-once
//   [6] SnapshotPeriod: added WEEKLY for weekly report granularity
//   [7] NetWorthSnapshot table added for net worth over time reports
//
// Changes from v2:
//   [8] CategorySnapshot table added — sparse strategy (write only when
//       transactions exist in that period, not for every category every day)
//   [9] Category + User relations updated to include CategorySnapshot
//
// Changes from v3:
//   [v4] Currency model dropped — currencyCode on Account is now a plain
//        string, validated in FE against a hardcoded currency list
//   [v4] is_commodity / unit_name removed from Account — replaced by Holding model
//   [v4] total_quantity / total_cost removed from AccountSnapshot — now on
//        Holding directly
//   [v4] Holding model added — multi-commodity positions within an ASSET account
//   [v4] holdingId added to JournalEntry
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

// Roles on a shared account:
// - OWNER  → full control, can delete account, manage members
// - ADMIN  → can edit transactions, invite members
// - EDITOR → can create/edit transactions, cannot manage members
// - VIEWER → read-only access
enum AccountRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// Double-entry: every transaction produces exactly one DEBIT and one CREDIT.
// Invariant: SUM(all DEBIT amounts) = SUM(all CREDIT amounts) at all times.
enum JournalEntryType {
  DEBIT
  CREDIT
}

// Snapshot granularity for report charts.
// WEEKLY added to support weekly report views without approximating from DAILY.
enum SnapshotPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

// Plain-language transaction kind. Drives which double-entry mapping the
// CreateTransactionUseCase applies and how reports route the row — see the
// TRANSACTION TYPE → REPORT ROUTING reference at the bottom of this file.
enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
  LOAN
}

// Loan lifecycle. ACTIVE while remaining_amount > 0; auto-flips to SETTLED
// when a settlement transaction brings remaining_amount to 0.
enum LoanStatus {
  ACTIVE
  SETTLED
}

// Who owes whom for a Loan:
//   LENT     → they owe you  (origin debits the system Receivables ASSET)
//   BORROWED → you owe them  (origin credits the system Payables LIABILITY)
// Settlement direction is derived: LENT → collection (money in),
// BORROWED → repayment (money out). Not stored per settlement.
enum LoanDirection {
  LENT
  BORROWED
}

// =============================================================================
// USERS
// =============================================================================
// Single table for auth + profile + preferences.
// Rationale: simpler queries, no joins for basic user info.
// Easy to split later via migration if the table grows too wide.
// -----------------------------------------------------------------------------

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String @map("password_hash")

  // Profile
  name      String
  avatarUrl String? @map("avatar_url")

  // Preferences
  language        String  @default("en")
  theme           String  @default("system") // "light" | "dark" | "system"
  notificationsOn Boolean @default(true) @map("notifications_on")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  ownedAccounts     Account[]          @relation("AccountOwner")
  accountMembers    AccountUser[]
  categories        Category[]
  transactions      Transaction[]
  contacts          Contact[]
  loans             Loan[]
  netWorthSnapshots NetWorthSnapshot[]
  categorySnapshots CategorySnapshot[]

  @@map("users")
}

// =============================================================================
// ACCOUNTS
// =============================================================================
// Represents a financial account (e.g. "Cash wallet", "Vietcombank", "Gold").
//
// Seeding at signup — 3 default accounts always created:
//   1. Cash wallet    (ASSET)   — most universal starting account
//   2. General income (INCOME)  — needed to record any money coming in
//   3. General expense(EXPENSE) — needed to record any spending
// LIABILITY and EQUITY are skipped at signup — users add them when needed.
//
// currencyCode:
//   Stored as a plain string (no FK to a Currency table). The FE validates
//   it against a hardcoded currency list — no server-side currency table needed.
//
// Commodity tracking:
//   Moved to the Holding model. An ASSET account can have multiple holdings
//   (e.g. gold, BTC, shares) — each holding tracks its own quantity and cost
//   basis. is_commodity and unit_name no longer exist on Account.
//
// current_balance:
//   Running balance updated atomically with each transaction.
//   Avoids recalculating from all journal entries on every load.
//   Balance formula differs by account type — see notes at bottom of file.
// -----------------------------------------------------------------------------

model Account {
  id           String      @id @default(uuid())
  ownerId      String      @map("owner_id")
  name         String
  type         AccountType
  currencyCode String      @map("currency_code")

  // Balance tracking
  initialBalance Decimal @default(0) @map("initial_balance") @db.Decimal(18, 4)
  currentBalance Decimal @default(0) @map("current_balance") @db.Decimal(18, 4)

  isActive  Boolean   @default(true) @map("is_active")
  isDefault Boolean   @default(false) @map("is_default") // true = seeded at signup
  // System accounts are bookkeeping plumbing hidden from the user's account
  // list and pickers: the seeded General income / General expense pair, plus
  // the lazily-created loan Receivables (ASSET) / Payables (LIABILITY).
  // Looked up by (owner_id, is_system, type).
  isSystem  Boolean   @default(false) @map("is_system")
  deletedAt DateTime? @map("deleted_at") // soft delete — never hard delete

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  owner              User              @relation("AccountOwner", fields: [ownerId], references: [id])
  members            AccountUser[]
  snapshots          AccountSnapshot[]
  journalEntries     JournalEntry[]
  debitTransactions  Transaction[]     @relation("DebitAccount")
  creditTransactions Transaction[]     @relation("CreditAccount")
  holdings           Holding[] // only ASSET accounts should have holdings — enforced in service layer

  @@map("accounts")
}

// =============================================================================
// ACCOUNT USERS (join table — shared accounts)
// =============================================================================
// Enables sharing an account between multiple users with role-based access.
// The account owner is always seeded here with role OWNER at account creation.
// Composite unique constraint prevents duplicate user+account rows.
// -----------------------------------------------------------------------------

model AccountUser {
  id        String      @id @default(uuid())
  accountId String      @map("account_id")
  userId    String      @map("user_id")
  role      AccountRole @default(VIEWER)
  joinedAt  DateTime    @default(now()) @map("joined_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  // One row per user per account — prevents duplicate role entries
  @@unique([accountId, userId])
  @@map("account_users")
}

// =============================================================================
// ACCOUNT SNAPSHOTS
// =============================================================================
// Periodic balance snapshots for report charts (daily, weekly, monthly).
// Avoids recalculating balances from all journal entries on every report load.
//
// How the snapshot job works:
//   For each period end (day/week/month):
//     For each account:
//       → read current_balance (already up to date from transactions)
//       → write one AccountSnapshot row
//     For each user:
//       → sum ASSET balances - LIABILITY balances
//       → write one NetWorthSnapshot row
//
// The unique constraint on (account_id, period_type, period_date) also
// acts as the composite index for report queries — no separate index needed.
// -----------------------------------------------------------------------------

model AccountSnapshot {
  id        String @id @default(uuid())
  accountId String @map("account_id")

  balance Decimal @db.Decimal(18, 4)

  periodType SnapshotPeriod @map("period_type")
  periodDate DateTime       @map("period_date") // the day/week/month this snapshot represents

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  account Account @relation(fields: [accountId], references: [id])

  // One snapshot per account per period type per date
  @@unique([accountId, periodType, periodDate])
  @@map("account_snapshots")
}

// =============================================================================
// NET WORTH SNAPSHOTS
// =============================================================================
// Pre-computed net worth per user per period for the net worth over time chart.
// Net worth = SUM(all ASSET account balances) - SUM(all LIABILITY balances).
//
// Without this table, the net worth chart would need to aggregate ALL account
// snapshots for ALL of a user's accounts on every page load — the most
// expensive query in the app. This table reduces it to a single lookup.
//
// Populated by the same background job that writes AccountSnapshot rows.
// For shared accounts: only the owner's accounts count toward their net worth.
// -----------------------------------------------------------------------------

model NetWorthSnapshot {
  id         String         @id @default(uuid())
  userId     String         @map("user_id")
  netWorth   Decimal        @map("net_worth") @db.Decimal(18, 4)
  periodType SnapshotPeriod @map("period_type")
  periodDate DateTime       @map("period_date")
  createdAt  DateTime       @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  // One net worth snapshot per user per period type per date
  @@unique([userId, periodType, periodDate])
  @@map("net_worth_snapshots")
}

// =============================================================================
// DEFAULT CATEGORIES (seed data — read only, never modified by users)
// =============================================================================
// Master list of categories copied into every new user's account at signup.
// Kept separate from user Category rows so:
//   - Defaults can be updated globally without touching user data
//   - User copies are fully independent — edit/delete freely
//
// Sorted alphabetically by name at query time — no sort_order field needed.
// -----------------------------------------------------------------------------

model DefaultCategory {
  id          String      @id @default(uuid())
  name        String
  icon        String
  accountType AccountType @map("account_type")

  // Relations
  subCategories DefaultSubCategory[]

  @@map("default_categories")
}

model DefaultSubCategory {
  id                String @id @default(uuid())
  defaultCategoryId String @map("default_category_id")
  name              String

  // Relations
  defaultCategory DefaultCategory @relation(fields: [defaultCategoryId], references: [id])

  @@map("default_sub_categories")
}

// =============================================================================
// CATEGORIES
// =============================================================================
// User-owned categories. Copied from DefaultCategory at signup, plus any
// custom ones the user creates afterward.
//
// account_type rules:
//   - Default categories: account_type set to specific type (e.g. EXPENSE)
//   - Custom categories:  account_type null = usable with any account type
//                         OR set to restrict to one type
//
// Soft delete applies to both default and custom categories uniformly.
// Deleting a default category sets deleted_at — same as a custom category.
// Historical transactions referencing a deleted category are unaffected.
// Sorted alphabetically by name in all queries.
// -----------------------------------------------------------------------------

model Category {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  name        String
  icon        String
  accountType AccountType? @map("account_type") // null = any account type
  isDefault   Boolean      @default(false) @map("is_default")

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user              User               @relation(fields: [userId], references: [id])
  subCategories     SubCategory[]
  categorySnapshots CategorySnapshot[]

  @@map("categories")
}

model SubCategory {
  id         String  @id @default(uuid())
  categoryId String  @map("category_id")
  name       String
  isDefault  Boolean @default(false) @map("is_default")

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  category     Category      @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@map("sub_categories")
}

// =============================================================================
// TRANSACTIONS
// =============================================================================
// Records a financial event between exactly two accounts (double-entry).
// Every transaction atomically produces 2 JournalEntry rows:
//   one DEBIT on debit_account, one CREDIT on credit_account.
//
// Example — buying groceries with cash:
//   debit_account  → Expense / Food      (expense balance increases)
//   credit_account → Asset  / Cash       (asset balance decreases)
//
// Currency: NOT stored on transactions. Derived from debitAccount.currencyCode.
//   In v1, both debit and credit accounts must share the same currency.
//   This is enforced in CreateTransactionUseCase, not the schema.
//
// Service-layer guards in CreateTransactionUseCase (not schema constraints):
//   1. debitAccount.ownerId  === userId  → ForbiddenException
//   2. creditAccount.ownerId === userId  → ForbiddenException
//   3. debitAccountId !== creditAccountId → BadRequestException
//   4. debitAccount.currencyCode === creditAccount.currencyCode → BadRequestException
//
// FK hooks for future features (nullable — not built yet):
//   contact_id        → v2: lender/borrower tracking
//   recurring_rule_id → v3: recurring transaction rules
// -----------------------------------------------------------------------------

model Transaction {
  id     String @id @default(uuid())
  userId String @map("user_id")

  // Plain-language kind — drives the double-entry mapping and report routing
  transactionType TransactionType @default(EXPENSE) @map("transaction_type")

  // The two accounts involved — both required, must be different
  debitAccountId  String @map("debit_account_id")
  creditAccountId String @map("credit_account_id")

  // Categorization — nullable: user can save now, categorize later
  subCategoryId String? @map("sub_category_id")

  // Description fields
  description String? // short label e.g. "Lunch at Pho 24"
  notes       String? // longer free-text notes

  // Amount in the account's currency (no conversion in v1)
  amount Decimal @db.Decimal(18, 4)

  date      DateTime // the actual date of the transaction (user-provided)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete — never hard delete

  // Report routing — server defaults this to true for TRANSFER and LOAN
  // (moving money around is neither income nor spending), false otherwise.
  // User-editable per transaction.
  excludeFromReports Boolean @default(false) @map("exclude_from_reports")

  // Loan linkage — set on the loan's origin transaction AND every settlement
  loanId String? @map("loan_id")

  // Lender/borrower on LOAN transactions
  contactId       String? @map("contact_id")
  // FK hook for future features — nullable, feature not built yet
  recurringRuleId String? @map("recurring_rule_id") // v3: recurring rules

  // Relations
  user           User           @relation(fields: [userId], references: [id])
  debitAccount   Account        @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount  Account        @relation("CreditAccount", fields: [creditAccountId], references: [id])
  subCategory    SubCategory?   @relation(fields: [subCategoryId], references: [id])
  loan           Loan?          @relation(fields: [loanId], references: [id])
  contact        Contact?       @relation(fields: [contactId], references: [id])
  journalEntries JournalEntry[]

  @@map("transactions")
}

// =============================================================================
// CONTACTS (lenders & borrowers)
// =============================================================================
// Minimal v1: a named counterparty for LOAN transactions plus a denormalized
// signed running balance, kept in sync with loans inside the same
// prisma.$transaction():
//   balance > 0 → they owe you   (net of your LENT loans)
//   balance < 0 → you owe them   (net of your BORROWED loans)
//
// Service-layer invariant: name unique among active (deleted_at IS NULL)
// contacts per user — enforced in the use-case, not the DB (soft-delete safe).
// -----------------------------------------------------------------------------

model Contact {
  id      String  @id @default(uuid())
  userId  String  @map("user_id")
  name    String
  balance Decimal @default(0) @db.Decimal(18, 4)

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id])
  loans        Loan[]
  transactions Transaction[]

  @@map("contacts")
}

// =============================================================================
// LOANS
// =============================================================================
// One row per individual debt, created atomically with its origin transaction
// (transaction_type = LOAN). Settlements are later LOAN transactions carrying
// the same loan_id; each decrements remaining_amount and status auto-flips to
// SETTLED when it reaches 0. Guard: settlement amount ≤ remaining_amount.
//
// Interest is display-only in v1 (no accrual math): e.g. rate 2 + period
// "yearly" renders as "2% · yearly".
// -----------------------------------------------------------------------------

model Loan {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  contactId       String        @map("contact_id")
  direction       LoanDirection
  principal       Decimal       @db.Decimal(18, 4)
  remainingAmount Decimal       @map("remaining_amount") @db.Decimal(18, 4)
  interestRate    Decimal?      @map("interest_rate") @db.Decimal(8, 4)
  interestPeriod  String?       @map("interest_period") // "yearly" | "monthly"
  status          LoanStatus    @default(ACTIVE)
  date            DateTime // origin date of the loan

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  transactions Transaction[] // origin + settlements

  @@map("loans")
}

// =============================================================================
// HOLDINGS
// =============================================================================
// A commodity position within an ASSET account.
// One ASSET account can hold multiple holdings (gold, silver, BTC, stocks, etc).
// Each holding tracks its own quantity and cost basis.
//
// currentQuantity — running total units owned, updated atomically with each transaction
// currentCost — running total cost basis in the account's currency
// Average cost per unit = currentCost / currentQuantity (derived at query time)
//
// Service-layer invariant: name must be unique among active (deletedAt IS NULL) holdings
// per account. Enforced in CreateHoldingUseCase, not at DB level (soft-delete compatibility).
// -----------------------------------------------------------------------------

model Holding {
  id              String    @id @default(uuid())
  accountId       String    @map("account_id")
  name            String // "Gold", "Bitcoin", "Apple"
  unitName        String    @map("unit_name") // "gram", "BTC", "share"
  currentQuantity Decimal   @default(0) @map("current_quantity") @db.Decimal(18, 8)
  currentCost     Decimal   @default(0) @map("current_cost") @db.Decimal(18, 4)
  deletedAt       DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account        Account        @relation(fields: [accountId], references: [id])
  journalEntries JournalEntry[]

  @@map("holdings")
}

// =============================================================================
// JOURNAL ENTRIES
// =============================================================================
// The immutable core of double-entry accounting.
// Every transaction produces exactly 2 rows: one DEBIT, one CREDIT.
//
// Invariant enforced by the application:
//   SUM(amount WHERE type = DEBIT) = SUM(amount WHERE type = CREDIT)
//
// IMMUTABILITY RULE:
//   Journal entries are NEVER updated or deleted after creation.
//   To reverse a transaction, create a new counter-transaction.
//   This preserves the full audit trail — standard accounting practice.
//   updatedAt is intentionally absent — this table is write-once.
//
// Commodity fields (quantity):
//   Only populated when account.is_commodity = true.
//   Example — buying 5g of gold for $300:
//     amount   = 300.0000    (total cost)
//     quantity = 5.00000000  (grams purchased)
//     unit_price NOT stored — computed at query time: amount / quantity = $60/g
//   Enables: total quantity owned, average cost = total_cost / total_quantity.
// -----------------------------------------------------------------------------

model JournalEntry {
  id            String           @id @default(uuid())
  transactionId String           @map("transaction_id")
  accountId     String           @map("account_id")
  type          JournalEntryType
  amount        Decimal          @db.Decimal(18, 4)

  // Commodity-only fields — null for regular (non-commodity) accounts.
  // Invariant: holdingId and quantity are always both null or both non-null.
  // unit_price is NOT stored — derived at query time: unit_price = amount / quantity
  quantity  Decimal? @db.Decimal(18, 8) // units bought/sold
  holdingId String?  @map("holding_id")

  // Write-once — no updatedAt (immutable table)
  createdAt DateTime @default(now()) @map("created_at")

  // Soft delete is the ONE permitted post-write mutation on this otherwise
  // write-once table — set together with the parent transaction's deletedAt.
  deletedAt DateTime? @map("deleted_at")

  // Relations
  transaction Transaction @relation(fields: [transactionId], references: [id])
  account     Account     @relation(fields: [accountId], references: [id])
  holding     Holding?    @relation(fields: [holdingId], references: [id])

  @@map("journal_entries")
}

// =============================================================================
// CATEGORY SNAPSHOTS
// =============================================================================
// Pre-aggregated category totals per period for trend charts and breakdowns.
// Enables fast rendering of:
//   - Spending breakdown by category per period (pie/bar chart)
//   - Income breakdown by category per period (pie/bar chart)
//   - Category trend over time (line chart — most expensive without this)
//
// SPARSE STRATEGY — only write rows when transactions actually exist:
//   The snapshot job aggregates journal_entries for the period, groups by
//   category_id, and writes one row per category that had activity.
//   Categories with no transactions in a period get NO row — not a zero row.
//   The chart layer fills missing periods with 0 at render time.
//
// Why sparse and not dense (write every category every period)?
//   A user with 20 categories × 2 entry types × 3 period types = 120 rows/day
//   dense. But only 3-5 categories are used daily → ~90 rows/day are wasted
//   zeros. Sparse keeps the table lean: ~10-15 rows/day vs 120, a 10x reduction.
//   At 100 users over 3 years: ~1.2M rows sparse vs ~13M rows dense.
//
// entryType = DEBIT  → spending  (e.g. Food expense)
// entryType = CREDIT → income    (e.g. Salary income)
// Stored separately so reports can filter cleanly without runtime arithmetic.
//
// Chart layer gap-filling pattern (TypeScript):
//   const filled = allPeriods.map(period => ({
//     period,
//     totalAmount: snapshots.find(s => s.periodDate === period)?.totalAmount ?? 0
//   }));
// -----------------------------------------------------------------------------

model CategorySnapshot {
  id         String @id @default(uuid())
  categoryId String @map("category_id")
  userId     String @map("user_id")

  totalAmount Decimal          @map("total_amount") @db.Decimal(18, 4)
  entryType   JournalEntryType @map("entry_type") // DEBIT = spending, CREDIT = income

  periodType SnapshotPeriod @map("period_type")
  periodDate DateTime       @map("period_date")
  createdAt  DateTime       @default(now()) @map("created_at")

  // Relations
  category Category @relation(fields: [categoryId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  // One row per category per user per entry type per period
  @@unique([categoryId, userId, entryType, periodType, periodDate])
  @@map("category_snapshots")
}

// =============================================================================
// BALANCE CALCULATION REFERENCE
// =============================================================================
// Account types have a "normal balance side" in double-entry accounting.
// This determines whether DEBIT or CREDIT increases the account balance.
//
//   ASSET    → normal balance = DEBIT  → balance + debit - credit
//   EXPENSE  → normal balance = DEBIT  → balance + debit - credit
//   LIABILITY→ normal balance = CREDIT → balance - debit + credit
//   INCOME   → normal balance = CREDIT → balance - debit + credit
//   EQUITY   → normal balance = CREDIT → balance - debit + credit
//
// current_balance is updated inside prisma.$transaction() alongside journal
// entry creation — atomically, so they can never get out of sync.
//
// NET WORTH CALCULATION (for NetWorthSnapshot):
//   net_worth = SUM(current_balance WHERE type IN [ASSET])
//             - SUM(current_balance WHERE type IN [LIABILITY])
//
// TRANSACTION TYPE → REPORT ROUTING:
//   EXPENSE  → spending reports (by category, trends); exclude_from_reports=false
//   INCOME   → income reports; exclude_from_reports=false
//   TRANSFER → excluded from in/out reports (exclude_from_reports=true);
//              affects account balances only
//   LOAN     → excluded from income/spending (exclude_from_reports=true);
//              affects net worth via the system Receivables (ASSET) /
//              Payables (LIABILITY) account balances
//   All in/out report aggregations filter exclude_from_reports = false.
//   Account lists and pickers exclude is_system accounts.
//
// REPORT TABLE SUMMARY:
//   account_snapshots   → account balance over time, commodity holdings
//   net_worth_snapshots → net worth over time (pre-computed, fast)
//   category_snapshots  → spending/income by category, trends over time (sparse)
//   transactions        → transaction list with filters (direct query)
// =============================================================================
